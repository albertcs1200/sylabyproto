@{
    ViewData["Title"] = "Gestión del Sílabo";
    var isDirector = (bool)ViewBag.IsDirector;
    var compliances = (List<SyllabusCompliance>)ViewBag.Compliances;
    var proposals = (List<SyllabusUpdateProposal>)ViewBag.Proposals;
}

<div class="container my-4">
    <!-- Success Alert -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-lg text-white mb-4" role="alert" style="background: linear-gradient(135deg, #10b981, #059669); border-radius: 12px;">
            <strong>✨ ¡Éxito!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Header Banner -->
    <div class="glass-card p-5 mb-4" style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.15), rgba(6, 182, 212, 0.05));">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <span class="fs-1">📚</span>
                    <h1 class="mb-0" style="font-family: var(--font-heading);">Gestión y Cumplimiento del Sílabo</h1>
                </div>
                <p class="text-secondary mb-0">Registra tus cumplimientos semanales de temas y plantea propuestas de mejora académica de forma segura.</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                @if (isDirector)
                {
                    <span class="badge bg-danger py-2 px-3 fs-6 mb-2 d-inline-block border border-danger shadow-sm" style="box-shadow: 0 0 10px rgba(239, 68, 68, 0.3) !important;">
                        👑 ROL: DIRECTOR ACADÉMICO
                    </span>
                    <a asp-action="AdminPanel" class="btn btn-outline-glow btn-sm w-100 mt-2">Acceder al Panel Director</a>
                }
                else
                {
                    <span class="badge bg-primary py-2 px-3 fs-6 mb-2 d-inline-block border border-primary shadow-sm" style="box-shadow: 0 0 10px rgba(99, 102, 241, 0.3) !important;">
                        👨‍🏫 ROL: DOCENTE
                    </span>
                }
            </div>
        </div>
    </div>

    <!-- Quick Action Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="glass-card p-4 h-100 d-flex flex-column justify-content-between">
                <div>
                    <h3 class="h4 text-light mb-2">✍️ Registrar Avance del Sílabo</h3>
                    <p class="text-secondary small">Informa el cumplimiento de los temas previstos del sílabo, porcentaje de avance en clase y observaciones.</p>
                </div>
                <div class="mt-4">
                    <a asp-action="RegisterCompliance" class="btn btn-glow w-100">+ Formulario de Cumplimiento</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="glass-card p-4 h-100 d-flex flex-column justify-content-between">
                <div>
                    <h3 class="h4 text-light mb-2">💡 Propuesta de Actualización</h3>
                    <p class="text-secondary small">Sugiere mejoras, inclusión de nuevos temas, bibliografía complementaria o metodologías innovadoras para el sílabo.</p>
                </div>
                <div class="mt-4">
                    <a asp-action="CreateProposal" class="btn btn-outline-glow w-100">+ Crear Propuesta de Cambio</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Tables Grid -->
    <div class="row g-4">
        <!-- Compliances Table -->
        <div class="col-lg-6">
            <div class="glass-card p-4 h-100">
                <h3 class="h4 text-light mb-3">📅 @(isDirector ? "Todos los Cumplimientos" : "Mis Temas Registrados")</h3>
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0" style="background-color: transparent !important;">
                        <thead>
                            <tr class="text-secondary small border-bottom" style="border-color: var(--border-color);">
                                <th>Curso</th>
                                <th>Tema / Unidad</th>
                                <th class="text-center">Avance</th>
                                <th class="text-end">Fecha</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in compliances)
                            {
                                <tr class="align-middle border-bottom" style="border-color: var(--border-color);">
                                    <td>
                                        <div class="fw-bold text-white small">@c.CourseName</div>
                                        @if (isDirector) { <span class="text-secondary" style="font-size: 0.75rem;">Docente: @c.TeacherName</span> }
                                    </td>
                                    <td class="text-secondary small">@c.Topic</td>
                                    <td class="text-center">
                                        <span class="badge" style="background-color: rgba(16, 185, 129, 0.15); color: var(--color-done);">@c.CompliancePercentage%</span>
                                    </td>
                                    <td class="text-end text-secondary small">@c.ClassDate.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                            @if (!compliances.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-secondary py-4 small">No se han registrado cumplimientos aún.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Proposals Table -->
        <div class="col-lg-6">
            <div class="glass-card p-4 h-100">
                <h3 class="h4 text-light mb-3">💡 @(isDirector ? "Todas las Propuestas" : "Mis Propuestas de Mejora")</h3>
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0" style="background-color: transparent !important;">
                        <thead>
                            <tr class="text-secondary small border-bottom" style="border-color: var(--border-color);">
                                <th>Curso</th>
                                <th>Modificación</th>
                                <th class="text-center">Estado</th>
                                @if (isDirector) { <th class="text-end">Acción</th> }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in proposals)
                            {
                                <tr class="align-middle border-bottom" style="border-color: var(--border-color);">
                                    <td>
                                        <div class="fw-bold text-white small">@p.CourseName</div>
                                        @if (isDirector) { <span class="text-secondary" style="font-size: 0.75rem;">Propone: @p.ProposerName</span> }
                                    </td>
                                    <td class="text-secondary small">@p.ChangeType</td>
                                    <td class="text-center">
                                        @if (p.IsApproved)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success py-1 px-2" style="font-size: 0.75rem;">Aprobada</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning py-1 px-2" style="font-size: 0.75rem;">Pendiente</span>
                                        }
                                    </td>
                                    @if (isDirector)
                                    {
                                        <td class="text-end">
                                            @if (!p.IsApproved)
                                            {
                                                <form asp-action="ApproveProposal" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@p.Id" />
                                                    <button type="submit" class="btn btn-glow py-1 px-2 small btn-sm" style="font-size: 0.75rem;">✓ Aprobar</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-secondary small">Ninguna</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                            @if (!proposals.Any())
                            {
                                <tr>
                                    <td colspan="@(isDirector ? 4 : 3)" class="text-center text-secondary py-4 small">No se han registrado propuestas de actualización aún.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
